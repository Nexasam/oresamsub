{
  "expo": {
    "name": "OresamSub",
    "owner": "oresamsub",
    "slug": "oresamsub",
    "scheme": "oresamsub",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oresamsub.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.oresamsub.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow OresamSub to select a beneficiary from your contacts."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow OresamSub to use Face ID to unlock your saved session."
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5d00411d-2685-4ba6-b011-10c1f88023d1"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/5d00411d-2685-4ba6-b011-10c1f88023d1"
    }
  }
}
